{
    "name": "danevan",
    "version": "0.1.0",
    "private": true,
    "description": "Danevan desktop database client with Vue and Vite. Supports MySQL, PostgreSQL, SQLite, SQL Server, and MS Access.",
    "homepage": "https://github.com/mergehez/danevan#readme",
    "bugs": {
        "url": "https://github.com/mergehez/danevan/issues"
    },
    "license": "MIT",
    "author": {
        "name": "Mergesoft",
        "email": "argesozdogan@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mergehez/danevan.git"
    },
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "type": "module",
    "scripts": {
        "build": "vp build && electrobun build",
        "ready": "vp check && vp run -r test && vp run build",
        "prepare": "vp config",
        "lint": "vp check --fix && vue-tsc --noEmit",
        "build:api": "bun run ./scripts/build-api.ts",
        "bundle:msaccess-runtime": "bun run ./scripts/vendor-msaccess-runtime.ts",
        "test:ui": "vitest run",
        "test:e2e": "playwright test",
        "test:msaccess": "bun msaccess-test.ts",
        "test:remote": "bun run ./scripts/test-remote-db.ts",
        "release:audit": "bash ./scripts/release-audit.sh",
        "release:validate": "vitest run && vp run build",
        "release:mac": "bun run ./scripts/build.ts",
        "release:mac:signed": "bun run ./scripts/build.ts --signed",
        "release:mac:notarize": "bun run ./scripts/build.ts --notarize",
        "dev": "bun --watch run apps/app/backend/devServer.ts & sleep 2 && VITE_DEV2=true vp dev --port 3263",
        "dev:app": "vp build && concurrently \"vp dev --port 3263\" \"electrobun dev --watch\"",
        "build:canary": "electrobun build --env=canary",
        "build:stable": "electrobun build --env=stable"
    },
    "dependencies": {
        "electrobun": "^1.18.1",
        "tailwind-merge": "^3.6.0",
        "vue": "^3.5.33"
    },
    "devDependencies": {
        "@mergehez/barke": "^0.1.1",
        "@playwright/test": "^1.61.1",
        "@tailwindcss/vite": "^4.2.4",
        "@types/bun": "^1.3.14",
        "@types/node": "^26.1.1",
        "@types/three": "^0.185.1",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/test-utils": "^2.4.11",
        "concurrently": "^9.2.4",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import": "^2.32.0",
        "jsdom": "^29.1.1",
        "oxfmt": "^0.59.0",
        "oxlint": "^1.74.0",
        "oxlint-tsgolint": "^0.25.0",
        "tailwindcss": "^4.2.4",
        "typescript": "^6.0.3",
        "vite-plus": "catalog:",
        "vitest": "catalog:",
        "vue-tsc": "^3.2.7"
    },
    "overrides": {
        "vite": "catalog:",
        "vitest": "catalog:"
    },
    "engines": {
        "node": ">=22.12.0"
    },
    "packageManager": "bun@1.3.13",
    "catalog": {
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
        "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
        "vite-plus": "latest"
    },
    "productName": "Danevan"
}
